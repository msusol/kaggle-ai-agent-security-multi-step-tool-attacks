# ── JED Attack — llama.cpp Server ─────────────────────────────────────────────
#
# Builds the llama-server C++ binary with CUDA support — the same runtime
# the Kaggle evaluator uses to serve GPT-OSS 20B and Gemma 4 26B.
#
# The Python wrapper (llama-cpp-python) does NOT support the --jinja flag
# needed to evaluate GPT-OSS's embedded Jinja2 chat template (including
# the render_tool_namespace macro for tool injection). The C++ llama-server
# binary with --jinja does.
#
# Architecture: linux/arm64 (DGX Spark GB10 aarch64)
#
# Build:
#   make build-llama        (first build ~20 min — compiles CUDA kernels)
#
# Run (handled by scripts/llama-serve.sh):
#   docker run --rm --privileged --gpus all -p 8082:8082 \
#     -v /path/to/gguf:/models:ro \
#     jed-llama:latest \
#     llama-server --model /models/gpt-oss-20b-mxfp4.gguf \
#       --host 0.0.0.0 --port 8082 --ctx-size 8192 --n-gpu-layers -1 --jinja
# ─────────────────────────────────────────────────────────────────────────────

FROM nvcr.io/nvidia/pytorch:26.04-py3

RUN apt-get update && apt-get install -y --no-install-recommends \
        cmake git \
    && rm -rf /var/lib/apt/lists/*

# Clone llama.cpp and build llama-server with CUDA + Blackwell support.
# GGML_CUDA=ON enables GPU offload.
# CMAKE_CUDA_ARCHITECTURES covers Hopper (90), Blackwell B100 (100), GB10 (120).
RUN git clone --depth 1 https://github.com/ggerganov/llama.cpp /opt/llama.cpp \
    && cmake -B /opt/llama.cpp/build /opt/llama.cpp \
        -DGGML_CUDA=ON \
        -DCMAKE_CUDA_ARCHITECTURES="90;100;120" \
        -DLLAMA_BUILD_SERVER=ON \
        -DCMAKE_BUILD_TYPE=Release \
    && cmake --build /opt/llama.cpp/build --target llama-server -j$(nproc)

ENV PATH="/opt/llama.cpp/build/bin:${PATH}"

# huggingface_hub for model downloads (hf CLI, >= 1.20.0 for 'hf download')
RUN pip install --no-cache-dir "huggingface_hub[cli]>=1.20.0"

EXPOSE 8082

CMD ["llama-server", "--help"]
